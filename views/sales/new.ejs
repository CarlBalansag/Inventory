<% layout('layout/boilerplate') %>
<div class="page-header">
  <h1 class="page-title" style="margin:0">Record sale</h1>
  <a href="/sales" class="btn btn-ghost">Cancel</a>
</div>

<% if (items.length === 0) { %>
  <div class="note">No items with available stock. <a href="/items/new">Add an item</a> first.</div>
<% } else { %>
  <div class="form-card">
    <% if (errors && errors.length) { %>
      <div class="form-errors">
        <% for (let e of errors) { %><p class="form-error"><%= e.msg %></p><% } %>
      </div>
    <% } %>

    <form action="/sales" method="POST">
      <div class="form-row">
        <div class="field">
          <label for="item">Item *</label>
          <select id="item" name="item" required>
            <option value="">— Select an item —</option>
            <% for (let i of items) { %>
              <option
                value="<%= i._id %>"
                data-qty="<%= i.availableQty %>"
                <%= old.item === String(i._id) ? 'selected' : '' %>>
                <%= i.name %> (paid $<%= i.purchasePrice.toFixed(2) %> · <%= i.availableQty %> available)
              </option>
            <% } %>
          </select>
        </div>
        <div class="field">
          <label for="quantitySold">Quantity *</label>
          <select id="quantitySold" name="quantitySold" required>
            <option value="">— Select item first —</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="field">
          <label for="salePrice">Sale price (per unit) *</label>
          <div class="prefix-wrap">
            <span class="prefix">$</span>
            <input type="number" id="salePrice" name="salePrice" value="<%= old.salePrice || '' %>" required min="0" step="0.01" placeholder="0.00" />
          </div>
        </div>
        <div class="field">
          <label for="saleDate">Sale date *</label>
          <input type="date" id="saleDate" name="saleDate" value="<%= old.saleDate || '' %>" required />
        </div>
      </div>
      <div class="form-row form-row-full">
        <div class="field">
          <label for="platformSold">Platform *</label>
          <input type="text" id="platformSold" name="platformSold" value="<%= old.platformSold || '' %>" placeholder="e.g. eBay, Mercari, StockX" required />
        </div>
      </div>
      <div class="form-row form-row-full">
        <div class="field">
          <label for="buyerNotes">Buyer notes</label>
          <textarea id="buyerNotes" name="buyerNotes"><%= old.buyerNotes || '' %></textarea>
        </div>
      </div>
      <div class="form-footer">
        <a href="/sales" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-primary">Record sale</button>
      </div>
    </form>
  </div>

  <script>
    (function () {
      var itemSelect = document.getElementById('item');
      var qtySelect  = document.getElementById('quantitySold');
      var oldQty     = '<%= old.quantitySold || "" %>';

      function buildQtyOptions(max) {
        qtySelect.innerHTML = '';
        if (!max || max < 1) {
          var opt = document.createElement('option');
          opt.value = '';
          opt.textContent = '— Select item first —';
          qtySelect.appendChild(opt);
          return;
        }
        for (var i = 1; i <= max; i++) {
          var opt = document.createElement('option');
          opt.value = i;
          opt.textContent = i;
          if (String(i) === oldQty) opt.selected = true;
          qtySelect.appendChild(opt);
        }
      }

      itemSelect.addEventListener('change', function () {
        var selected = itemSelect.options[itemSelect.selectedIndex];
        var qty = parseInt(selected.dataset.qty) || 0;
        buildQtyOptions(qty);
        oldQty = ''; // clear old qty after first change so it doesn't stick
      });

      // On page load, if an item is already selected (e.g. after validation error) rebuild the dropdown
      if (itemSelect.value) {
        var selected = itemSelect.options[itemSelect.selectedIndex];
        buildQtyOptions(parseInt(selected.dataset.qty) || 0);
      }
    })();
  </script>
<% } %>
